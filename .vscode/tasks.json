{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure (Release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B", "build",
                "-DCMAKE_BUILD_TYPE=Release",
                "-G", "MinGW Makefiles",
                "-DCMAKE_CXX_COMPILER=C:/msys64/mingw64/bin/g++.exe",
                "-DCMAKE_C_COMPILER=C:/msys64/mingw64/bin/gcc.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PATH": "C:/msys64/mingw64/bin;${env:PATH}"
                }
            },
            "group": "build"
        },
        {
            "label": "Build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build",
                "-j4"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PATH": "C:/msys64/mingw64/bin;${env:PATH}"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": "Configure (Release)"
        }
    ]
}